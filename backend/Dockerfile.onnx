# sherpa-onnx GPU worker image.
# Batched ASR via decode_streams() for high GPU utilization.

FROM nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
      python3.12 python3.12-venv python3-pip \
      ffmpeg libsndfile1 curl ca-certificates bzip2 \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 \
 && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:${PATH}"

# Install sherpa-onnx CUDA wheel + diarization deps (no torch!)
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir \
      sherpa-onnx==1.12.29+cuda12.cudnn9 -f https://k2-fsa.github.io/sherpa/onnx/cuda.html \
 && pip install --no-cache-dir \
      numpy \
      soundfile \
      scipy \
      scikit-learn \
      huggingface_hub \
      onnxruntime

# Pre-download ASR + VAD models into the image
RUN mkdir -p /opt/models \
 && curl -SL https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8.tar.bz2 \
    | tar xj -C /opt/models \
 && curl -SL -o /opt/models/silero_vad.onnx \
    https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/silero_vad.onnx

# Pre-download diarization models (HuggingFace)
ENV HF_HOME=/opt/hf_cache

RUN python -c "\
from huggingface_hub import hf_hub_download; \
hf_hub_download('onnx-community/pyannote-segmentation-3.0', 'onnx/model.onnx'); \
hf_hub_download('onnx-community/wespeaker-voxceleb-resnet34-LM', 'onnx/model.onnx'); \
print('diarization models cached')"

# App deps — install from pyproject.toml before copying src so that
# source-only changes don't invalidate the pip install layer
RUN groupadd -g 1001 app && useradd -u 1001 -g app -s /bin/bash -m app

WORKDIR /app
COPY pyproject.toml README.md ./

# Create minimal src so pip install can resolve the package
RUN mkdir -p src/cassandra_yt_mcp && touch src/cassandra_yt_mcp/__init__.py \
 && pip install --no-cache-dir ".[onnx]"

# Now copy actual source — this layer is cheap to rebuild
COPY src ./src
RUN pip install --no-cache-dir --no-deps "."

RUN mkdir -p /data && chown -R app:app /app /data

USER app

ENV PYTHONUNBUFFERED=1 \
    PORT=3000 \
    WORKER_PORT=3001 \
    HOST=0.0.0.0 \
    DATA_DIR=/data \
    ROLE=worker \
    TRANSCRIPTION_ENGINE=onnx \
    HF_HOME=/opt/hf_cache \
    SHERPA_MODELS_DIR=/opt/models/sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8 \
    SILERO_VAD_MODEL=/opt/models/silero_vad.onnx

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD curl -fsS "http://127.0.0.1:${WORKER_PORT}/worker/healthz" >/dev/null 2>&1 || exit 1

CMD ["cassandra-yt-mcp-backend"]
